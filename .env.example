# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE CONFIG - Used for programmatic dynamic setup of Firestore and Auth in code
FIREBASE_API_KEY=AIzaSy_MockFirebaseApiKeyForSandboxAndEmulator
FIREBASE_PROJECT_ID=capcut-editor-aistudio
FIREBASE_APPLICATION_ID=1:1234567890:android:abcdef123456
GOOGLE_WEB_CLIENT_ID=1234567890-abcdef.apps.googleusercontent.com
